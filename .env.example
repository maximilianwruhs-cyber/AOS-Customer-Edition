# AOS Environment Variables
# Copy this to .env and customize

# LLM Backend URL (set by remote_hosts.json, override here if needed)
# OLLAMA_URL=http://localhost:1234/v1

# Default model for benchmarks
# AOS_MODEL=qwen2.5-coder-1.5b-instruct

# API Authentication (optional — disabled by default for local-only use)
# AOS_API_KEY=your-secret-key-here

# Arena defaults
# AOS_TOKENS_PER_ROUND=2048
# AOS_INITIAL_BALANCE=100.0

# RAG Pipeline — PostgreSQL (pgvector)
# PGVECTOR_HOST=localhost
# PGVECTOR_PORT=5432
# PGVECTOR_DB=aos_rag
# PGVECTOR_USER=aos
# PGVECTOR_PASSWORD=aos_local_dev

# RAG Pipeline — Embedding & Generation Models (via Ollama)
# RAG_EMBED_MODEL=nomic-embed-text
# RAG_LLM_MODEL=llama3
